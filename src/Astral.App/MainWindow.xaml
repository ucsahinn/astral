<Window x:Class="Astral.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Astral"
        Width="1280"
        Height="720"
        MinWidth="1280"
        MinHeight="720"
        MaxWidth="1280"
        MaxHeight="720"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">
    <Grid ClipToBounds="True">
        <MediaElement x:Name="BackgroundVideo"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Close"
                      Stretch="UniformToFill"
                      Volume="0"
                      Opacity="0.92"
                      IsHitTestVisible="False"
                      Loaded="BackgroundVideo_Loaded"
                      MediaEnded="BackgroundVideo_MediaEnded"
                      MediaFailed="BackgroundVideo_MediaFailed" />

        <Rectangle IsHitTestVisible="False">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#64040710" Offset="0" />
                    <GradientStop Color="#42091322" Offset="0.34" />
                    <GradientStop Color="#12071120" Offset="0.72" />
                    <GradientStop Color="#1C040710" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.10">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.72,0.42"
                                     GradientOrigin="0.72,0.38"
                                     RadiusX="0.70"
                                     RadiusY="0.78">
                    <GradientStop Color="#00121A30" Offset="0" />
                    <GradientStop Color="#1EFF3F75" Offset="0.38" />
                    <GradientStop Color="#225EEBFF" Offset="0.66" />
                    <GradientStop Color="#00050712" Offset="1" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.20">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                    <GradientStop Color="#A7040710" Offset="0" />
                    <GradientStop Color="#3C040710" Offset="0.42" />
                    <GradientStop Color="#00040710" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.07">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.26,0.44"
                                     GradientOrigin="0.22,0.36"
                                     RadiusX="0.52"
                                     RadiusY="0.72">
                    <GradientStop Color="#7E61F6FF" Offset="0" />
                    <GradientStop Color="#2639E8FF" Offset="0.58" />
                    <GradientStop Color="#00050712" Offset="1" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle IsHitTestVisible="False" Opacity="0.05">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#307DEBFF" Offset="0" />
                    <GradientStop Color="#00040710" Offset="0.32" />
                    <GradientStop Color="#185DFF92" Offset="0.68" />
                    <GradientStop Color="#00040710" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="74" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource PremiumLineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18,0"
                    MaxWidth="1244">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#9B0C1728" Offset="0" />
                        <GradientStop Color="#7817253C" Offset="0.54" />
                        <GradientStop Color="#64101D31" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="36"
                                      Direction="270"
                                      Opacity="0.42"
                                      ShadowDepth="0"
                                      Color="#63D9FF" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="62"
                            Height="62"
                            Margin="0,0,18,0"
                            CornerRadius="16"
                            BorderBrush="#B77DEBFF"
                            BorderThickness="1"
                            RenderTransformOrigin="0.5,0.5"
                            VerticalAlignment="Center">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="LogoScale"
                                                ScaleX="1"
                                                ScaleY="1" />
                                <RotateTransform x:Name="LogoTilt"
                                                 Angle="0" />
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoTilt"
                                                                       Storyboard.TargetProperty="Angle">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.45" Value="-3" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.7" Value="3" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.95" Value="-1.5" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:2.2" Value="0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:4.6" Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoScale"
                                                                       Storyboard.TargetProperty="ScaleX">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.45" Value="1.035" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.7" Value="1.015" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:2.2" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:4.6" Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LogoScale"
                                                                       Storyboard.TargetProperty="ScaleY">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.45" Value="1.035" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.7" Value="1.015" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:2.2" Value="1" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:4.6" Value="1" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <Border.Background>
                            <RadialGradientBrush Center="0.45,0.38"
                                                 GradientOrigin="0.32,0.24"
                                                 RadiusX="0.85"
                                                 RadiusY="0.85">
                                <GradientStop Color="#767DEBFF" Offset="0" />
                                <GradientStop Color="#3D5DFF92" Offset="0.44" />
                                <GradientStop Color="#A0101D31" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="26"
                                              Direction="270"
                                              Opacity="0.72"
                                              ShadowDepth="0"
                                              Color="#7DEBFF" />
                        </Border.Effect>
                        <Image Width="56"
                               Height="56"
                               Source="Assets/astral-mark.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="20"
                                   LineHeight="24"
                                   FontWeight="SemiBold"
                                   Text="Astral" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Desteklenen hedef kapsamı hazır." />
                    </StackPanel>

                    <Border Grid.Column="2"
                            x:Name="StatusBadge"
                            Padding="14,8"
                            CornerRadius="7"
                            Background="#8A101A2D"
                            BorderBrush="#B77DEBFF"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot"
                                     Width="8"
                                     Height="8"
                                     Margin="0,0,8,0"
                                     Fill="{StaticResource SecondaryTextBrush}" />
                            <TextBlock x:Name="StatusLabel"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="KAPALI" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="548" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="#C49CD4FF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="26,18"
                        MaxHeight="504"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#A20B1422" Offset="0" />
                            <GradientStop Color="#7E17243B" Offset="0.52" />
                            <GradientStop Color="#68101D31" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="64"
                                          Direction="270"
                                          Opacity="0.62"
                                          ShadowDepth="0"
                                          Color="#66D9FF" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                x:Name="ToggleButton"
                                Width="264"
                                Height="264"
                                Margin="0,-6,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#761A2240"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="3"
                                Cursor="Hand"
                                Click="ToggleButton_Click"
                                AutomationProperties.AutomationId="TunnelToggleButton"
                                AutomationProperties.Name="Seçili hedef bağlantısını aç veya kapat"
                                ToolTip="Seçili hedef bağlantısını aç veya kapat">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Width="{TemplateBinding Width}"
                                          Height="{TemplateBinding Height}">
                                        <Ellipse x:Name="OuterRing"
                                                 Margin="11"
                                                 Stroke="{TemplateBinding BorderBrush}"
                                                 StrokeThickness="{TemplateBinding BorderThickness}">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush Center="0.42,0.34"
                                                                     GradientOrigin="0.32,0.24"
                                                                     RadiusX="0.86"
                                                                     RadiusY="0.86">
                                                    <GradientStop Color="#D633426A" Offset="0" />
                                                    <GradientStop Color="#C329315A" Offset="0.34" />
                                                    <GradientStop Color="#95152547" Offset="0.72" />
                                                    <GradientStop Color="#8210182B" Offset="1" />
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="42"
                                                                  Direction="270"
                                                                  Opacity="0.95"
                                                                  ShadowDepth="0"
                                                                  Color="#56F07B" />
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse Width="244"
                                                 Height="244"
                                                 Stroke="#45FFFFFF"
                                                 StrokeThickness="1" />
                                        <Ellipse Margin="28"
                                                 Stroke="#B87DEBFF"
                                                 StrokeThickness="1.4">
                                            <Ellipse.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#C916243B" Offset="0" />
                                                    <GradientStop Color="#A724425C" Offset="0.55" />
                                                    <GradientStop Color="#8B3A5F65" Offset="1" />
                                                </LinearGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Ellipse x:Name="StateRing"
                                                 Width="202"
                                                 Height="202"
                                                 Fill="Transparent"
                                                 Stroke="#8F7DEBFF"
                                                 StrokeThickness="1"
                                                 StrokeDashArray="3 7" />
                                        <Ellipse Width="150"
                                                 Height="150"
                                                 Fill="Transparent"
                                                 Stroke="#4CF5F7FB"
                                                 StrokeThickness="1" />
                                        <Ellipse x:Name="CoreGlow"
                                                 Width="124"
                                                 Height="124"
                                                 Stroke="#785DFF92"
                                                 StrokeThickness="1.2">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush Center="0.46,0.38"
                                                                     GradientOrigin="0.34,0.25"
                                                                     RadiusX="0.82"
                                                                     RadiusY="0.82">
                                                    <GradientStop Color="#3E7DEBFF" Offset="0" />
                                                    <GradientStop Color="#275DFF92" Offset="0.48" />
                                                    <GradientStop Color="#14040710" Offset="1" />
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <StackPanel Width="170"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock x:Name="PowerIcon"
                                                       HorizontalAlignment="Center"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="58"
                                                       Foreground="{StaticResource AccentCyanBrush}"
                                                       Text="&#xE7E8;">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect BlurRadius="18"
                                                                      Direction="270"
                                                                      Opacity="0.86"
                                                                      ShadowDepth="0"
                                                                      Color="#5DFF92" />
                                                </TextBlock.Effect>
                                            </TextBlock>
                                            <TextBlock x:Name="ToggleButtonLabel"
                                                       Margin="0,8,0,0"
                                                       HorizontalAlignment="Center"
                                                       MaxWidth="164"
                                                       TextAlignment="Center"
                                                       TextWrapping="NoWrap"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Text="BAĞLAN" />
                                        </StackPanel>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="OuterRing"
                                                    Property="Fill"
                                                    Value="#9C253E54" />
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter TargetName="OuterRing"
                                                    Property="StrokeThickness"
                                                    Value="5" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.58" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <StackPanel Grid.Row="1"
                                    Margin="0,2,0,0"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="StatusMessage"
                                       MaxWidth="520"
                                       MaxHeight="58"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Bağlantı kapalı" />
                            <TextBlock x:Name="StatusDetail"
                                       MaxWidth="520"
                                       MaxHeight="48"
                                       Margin="0,6,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Hazır" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Margin="0,10,0,0"
                                Padding="14,10"
                                BorderBrush="#5F8EA7FF"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#56101D31" Offset="0" />
                                    <GradientStop Color="#3E19314A" Offset="0.55" />
                                    <GradientStop Color="#31101D31" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="StageProgressLabel"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="Hazır" />
                                    <TextBlock Grid.Column="1"
                                               x:Name="StageProgressPercent"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="0%" />
                                </Grid>

                                <ProgressBar x:Name="StageProgressBar"
                                             Margin="0,10,0,0"
                                             Style="{StaticResource StageProgressStyle}"
                                             Value="0" />

                                <UniformGrid Margin="0,10,0,0"
                                             Columns="4">
                                    <TextBlock x:Name="StageStepLock"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Hazırlık" />
                                    <TextBlock x:Name="StageStepSetup"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Kurulum" />
                                    <TextBlock x:Name="StageStepProfile"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Profil" />
                                    <TextBlock x:Name="StageStepTunnel"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Bağlantı" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="20,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            HorizontalAlignment="Right"
                            Width="638"
                            BorderBrush="#B58EC8FF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,10"
                            SnapsToDevicePixels="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#820B1422" Offset="0" />
                                <GradientStop Color="#66213A53" Offset="0.58" />
                                <GradientStop Color="#4A101D31" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="34"
                                              Direction="270"
                                              Opacity="0.40"
                                              ShadowDepth="0"
                                              Color="#4C72FF" />
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Left"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Hedef kapsamı" />
                            <TextBlock HorizontalAlignment="Left"
                                       Margin="0,4,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="8 hedef hazır" />
                            <TextBlock HorizontalAlignment="Left"
                                       Margin="0,2,0,7"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="8 hedef hazır · seçili kapsam bağlantıya dahil edilir." />
                            <UniformGrid x:Name="TargetCardsTopPanel"
                                         Width="462"
                                         Rows="1"
                                         Columns="4"
                                         HorizontalAlignment="Center"
                                         SnapsToDevicePixels="True" />
                            <UniformGrid x:Name="TargetCardsBottomPanel"
                                         Width="462"
                                         Margin="0,4,0,0"
                                         Rows="1"
                                         Columns="4"
                                         HorizontalAlignment="Center"
                                         SnapsToDevicePixels="True" />
                            <Border Margin="0,8,0,0"
                                    Width="586"
                                    Padding="9,6"
                                    BorderBrush="#3F9CD4FF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Background="#40101D31">
                                <TextBlock x:Name="TargetTestSummary"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Text="Kapsam durumu: seçili hedefler bağlantıya dahil edilir; Astral uygulamaları otomatik açmaz." />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            HorizontalAlignment="Right"
                            Margin="0,6,0,0"
                            Width="638"
                            BorderBrush="#B58EC8FF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#860B1422" Offset="0" />
                                <GradientStop Color="#7017243B" Offset="0.45" />
                                <GradientStop Color="#54101D31" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40"
                                              Direction="270"
                                              Opacity="0.38"
                                              ShadowDepth="0"
                                              Color="#63D9FF" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="İŞLETİM MERKEZİ" />

                            <Grid Grid.Row="1"
                                  Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Margin="0,0,14,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,7,0"
                                                   FontFamily="Segoe UI Emoji"
                                                   FontSize="13"
                                                   Text="🌙" />
                                        <TextBlock FontSize="12.5"
                                                   FontWeight="SemiBold"
                                                   Text="Arka planda çalıştır" />
                                    </StackPanel>
                            <TextBlock Grid.Row="1"
                                       x:Name="RunInBackgroundStatus"
                                       Margin="0,4,0,8"
                                       Visibility="Collapsed"
                                       TextWrapping="Wrap"
                                               FontSize="11"
                                               LineHeight="14"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="Pencere kapanınca bildirim alanında kalmaz." />
                                    <CheckBox Grid.Row="2"
                                              x:Name="RunInBackgroundToggle"
                                              Style="{StaticResource BrowserSwitchStyle}"
                                              HorizontalAlignment="Left"
                                              Checked="RunInBackgroundToggle_Changed"
                                              Unchecked="RunInBackgroundToggle_Changed"
                                              ToolTip="Pencere kapanınca çalışmaya devam et"
                                              AutomationProperties.Name="Arka planda çalıştırmayı aç veya kapat" />
                                </Grid>

                                <Rectangle Grid.Column="1"
                                           Width="1"
                                           Fill="#35FFFFFF" />

                                <Grid Grid.Column="2"
                                      Margin="14,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Margin="0,0,7,0"
                                                   FontFamily="Segoe UI Emoji"
                                                   FontSize="13"
                                                   Text="🚀" />
                                        <TextBlock Grid.Column="1"
                                                   FontSize="12.5"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   LineHeight="16"
                                                   Text="Windows açılışında çalıştır" />
                                    </Grid>
                            <TextBlock Grid.Row="1"
                                       x:Name="StartupStatus"
                                       Margin="0,4,0,8"
                                       Visibility="Collapsed"

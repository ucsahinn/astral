<Window x:Class="Astral.App.ReleaseNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Astral sürüm notları"
        Width="720"
        Height="640"
        MinWidth="720"
        MinHeight="580"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="22">
        <Border BorderBrush="{StaticResource PremiumLineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EF09131F" Offset="0" />
                    <GradientStop Color="#D914253A" Offset="0.48" />
                    <GradientStop Color="#C0181730" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="38"
                                  Direction="270"
                                  Opacity="0.46"
                                  ShadowDepth="0"
                                  Color="#63D9FF" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="54"
                            Height="54"
                            CornerRadius="14"
                            BorderBrush="#B77DEBFF"
                            BorderThickness="1">
                        <Border.Background>
                            <RadialGradientBrush Center="0.42,0.34"
                                                 GradientOrigin="0.3,0.22"
                                                 RadiusX="0.85"
                                                 RadiusY="0.85">
                                <GradientStop Color="#767DEBFF" Offset="0" />
                                <GradientStop Color="#345DFF92" Offset="0.48" />
                                <GradientStop Color="#A0101D31" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                        <Viewbox Width="26"
                                 Height="26"
                                 Stretch="Uniform">
                            <Canvas Width="24"
                                    Height="24"
                                    ClipToBounds="False">
                                <Path Stroke="{StaticResource PrimaryTextBrush}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Data="M6,3.5 L15.5,3.5 L20,8 L20,20.5 L6,20.5 Z M15.5,3.5 L15.5,8 L20,8 M9,11 L17,11 M9,14.5 L17,14.5 M9,18 L14,18" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="Astral VPN v2.2.30" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Bağlantı kanıtı ve cleanup hotfix'i" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Margin="0,24,0,20"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                CornerRadius="8"
                                BorderBrush="#5F8EA7FF"
                                BorderThickness="1"
                                Background="#63101D31">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentCyanBrush}"
                                           Text="KISA ÖZET" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="14"
                                           LineHeight="21"
                                           TextWrapping="Wrap"
                                           Text="Bu sürüm v2.2.29 üzerinde kalan app+web yanlış bağlı pozitiflerini, cleanup doğrulama boşluklarını ve live smoke kanıt kapısını düzeltir. Astral VPN hâlâ yalnız seçili hedefleri kapsar; genel sistem VPN'i gibi davranmaz." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,12"
                                Padding="16"
                                CornerRadius="8"
                                BorderBrush="#5263D9FF"
                                BorderThickness="1"
                                Background="#4E101D31">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="ANA DEĞİŞİKLİKLER" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Arka plan video kaynağı kullanıcının istediği CloudFront videosuyla güncellendi ve release paketine sabit hash ile eklenir." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Yerel video yüklenemezse aynı doğrulanmış CloudFront kaynağı tanılamalı CDN fallback olarak denenir." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Hedef kartlarına erişilebilir harici bağlantı ikonu eklendi; ikon seçim durumunu değiştirmeden hedefin güvenli HTTPS sayfasını açar." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Roblox aktif preset listesinden ve paket resource listesinden çıkarıldı; hedef paneli 8+7 düzende 15 hazır hedef gösterir." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Hedef linkleri domain allowlist ile sınırlandı; hatalı veya yabancı host metadata'sı güvenli preset domainine düşer." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Sol progress paneli süreç log satırı, daha okunur yüzde hesabı ve aktif adım chip'leriyle yenilendi." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Kapanış, yeniden başlatma ve güncelleme öncesi bağlantı kapatma akışları daha hızlı tepki verecek şekilde interaktif timeout kullanır." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Hedef doğrulama tanılaması web rota kanıtı, app profil kapsamı, sorunlu, atlanan ve bekleyen hedefleri ayrı ayrı yazar." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Hedef testi kartı web hedeflerinde OK, uygulama-only kapsamda APP, çalışan testlerde ... ve sorunlarda ! rozetleriyle daha net ayrım yapar." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Hedef ikonundan web açma test sonucunu beklemez; sayfa hemen açılır, kapsam testi arka planda güncellenir." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Discord gibi uygulama kapsamlı hedeflerde Astral uygulamayı kendisi başlatmaz; app trafiği için WireSock kapsamı ve adapter trafik kanıtı ayrı doğrulanır, dış-link butonu yalnız güvenli web girişini açar." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Wgcf/WireGuard yardımcı komut hatalarında private key, authorization, cookie ve token benzeri değerler loga yazılmadan maskelenir." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Windows animasyon azaltma tercihi açıksa arka plan videosu görünür kalır, daha sakin hızla oynar; yalnız ASTRAL_DISABLE_BACKGROUND_VIDEO=1 videoyu kapatır." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Paket manifesti Assets/background.mp4 dosyasının beklenen uzunluk ve SHA-256 değerini zorunlu doğrular." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Windows UI testi hedef kartı link butonlarını, klavye aktivasyonunu, video path'ini ve güncelleme butonu davranışını doğrular." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Profil temizleme ve yeniden başlatma sırasında pencere açık kaldığı sürece arka plan videosu gereksiz yere durdurulmaz." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Üretim uygulaması artık gerçek Windows Discord process denetleyicisini kullanır; açık Discord tünel profili hazırlandıktan sonra, app kanıtından önce yenilenir." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Kapanış, yeniden başlatma ve dispose akışlarında access-lock veya web-proxy timeout'u UI'ı kilitlemez; tanılamaya best-effort timeout olarak yazılır." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; App+web hedeflerde scoped web proxy kanıtı artık uygulama tünel kanıtı yerine geçmez; WireSock handshake veya adapter trafik kanıtı alınmazsa Astral bağlı demez." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Scoped web proxy kanıtından sonra adapter trafik baseline'ı sıfırlanır; WebProxy'nin kendi CONNECT trafiği app kanıtı gibi sayılmaz." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Discord açıksa tünel profili hazırlandıktan sonra yenilenir; Discord kapalıysa Astral otomatik başlatmadan ek aksiyon gerektiğini söyler." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Hedef aksiyonu gereken durum artık tam bağlı sayılmaz; yalnızca güvenli kapatma/cleanup için aktif tünel lifecycle olarak izlenir." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Disconnect akışı web proxy veya tünel kapsam temizliği doğrulanamazsa temiz kapanmış gibi raporlamaz; kullanıcıya Onar veya Profili Temizle aksiyonu gösterilir." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Live smoke script'i app kapsamı olan hedeflerde web kanıtını tek başına yeterli saymaz; hedef matrisi uygulama kanıtı eksikse kırmızı döner." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Hedef testi UI'ı HTTP CONNECT başarısını app kapsamı hazır gibi göstermez; profil kapsamını ayrı ve sınırlı bir kanıt türü olarak yazar." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Sürüm metadata'sı, updater, web proxy ve uygulama içi release bağlantısı v2.2.30 ile hizalandı." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,12"
                                Padding="16"
                                CornerRadius="8"
                                BorderBrush="#55F9D66B"
                                BorderThickness="1"
                                Background="#4C1C1A12">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningBrush}"
                                           Text="BAĞLANTI NOTU" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="13"
                                           LineHeight="21"
                                           TextWrapping="Wrap"
                                           Text="Astral bağlantı sırasında hedef kapsamını dar tutar: uygulama hedefleri AllowedApps içinde kalır, web hedeflerinde ise yalnız Astral.WebProxy tünele alınır. PAC dosyası sadece seçili hedef hostlarında PROXY, diğer tüm domainlerde DIRECT döndürür." />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="13"
                                           LineHeight="21"
                                           TextWrapping="Wrap"
                                           Text="Windows kod imzası bu pakette sertifika olmadığı için uygulanmadı. Web hedefleri HTTPS içeriğini çözmez; CONNECT host allowlist'iyle çalışır. Gerçek kullanıcı hesabıyla login sonucu servis tarafı, captcha, üçüncü taraf auth ve yerel tarayıcı PAC uyumuna bağlı kalabilir." />
                            </StackPanel>
                        </Border>

                        <TextBlock FontSize="11"
                                   LineHeight="18"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="SHA256: Paket üretildikten sonra GitHub release asset'i ile doğrulanır." />
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}"
                                   Text="Bu not, v2.2.30 hotfix kapsamını uygulama içinden hızlıca okuyabilmek için eklendi." />
                    <Button Grid.Column="1"
                            Margin="0,0,10,0"
                            Height="40"
                            Style="{StaticResource CommandButtonStyle}"
                            Click="OpenReleasePage_Click"
                            Content="GitHub release"
                            ToolTip="Sürüm sayfasını aç" />
                    <Button Grid.Column="2"
                            Height="40"
                            Style="{StaticResource PrimaryCommandButtonStyle}"
                            Click="Close_Click"
                            Content="Kapat" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

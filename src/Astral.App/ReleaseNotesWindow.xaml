<Window x:Class="Astral.App.ReleaseNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Astral sürüm notları"
        Width="720"
        Height="640"
        MinWidth="720"
        MinHeight="580"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="22">
        <Border BorderBrush="{StaticResource PremiumLineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EF09131F" Offset="0" />
                    <GradientStop Color="#D914253A" Offset="0.48" />
                    <GradientStop Color="#C0181730" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="38"
                                  Direction="270"
                                  Opacity="0.46"
                                  ShadowDepth="0"
                                  Color="#63D9FF" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="54"
                            Height="54"
                            CornerRadius="14"
                            BorderBrush="#B77DEBFF"
                            BorderThickness="1">
                        <Border.Background>
                            <RadialGradientBrush Center="0.42,0.34"
                                                 GradientOrigin="0.3,0.22"
                                                 RadiusX="0.85"
                                                 RadiusY="0.85">
                                <GradientStop Color="#767DEBFF" Offset="0" />
                                <GradientStop Color="#345DFF92" Offset="0.48" />
                                <GradientStop Color="#A0101D31" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                        <Viewbox Width="26"
                                 Height="26"
                                 Stretch="Uniform">
                            <Canvas Width="24"
                                    Height="24"
                                    ClipToBounds="False">
                                <Path Stroke="{StaticResource PrimaryTextBrush}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Data="M6,3.5 L15.5,3.5 L20,8 L20,20.5 L6,20.5 Z M15.5,3.5 L15.5,8 L20,8 M9,11 L17,11 M9,14.5 L17,14.5 M9,18 L14,18" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="Astral v2.2.9" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Discorder'dan Astral'a geçiş ve hedef kapsamı hotfix'i" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Margin="0,24,0,20"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                CornerRadius="8"
                                BorderBrush="#5F8EA7FF"
                                BorderThickness="1"
                                Background="#63101D31">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentCyanBrush}"
                                           Text="KISA ÖZET" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="14"
                                           LineHeight="21"
                                           TextWrapping="Wrap"
                                           Text="Bu sürüm Discorder hattından Astral adına geçişi kullanıcı tarafında tamamlayan geçiş notudur. Uygulama artık tek hedefli Discord aracı gibi davranmaz; seçilen uygulama ve web hedefleri için dar kapsamlı bağlantı yöneticisi olarak çalışır." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,12"
                                Padding="16"
                                CornerRadius="8"
                                BorderBrush="#5263D9FF"
                                BorderThickness="1"
                                Background="#4E101D31">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="GEÇİŞTEKİ ANA DEĞİŞİKLİKLER" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Ürün adı, ikon, uygulama başlığı, tanılama klasörü ve güncelleme hattı Astral çizgisine taşındı." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Discord-only ve tarayıcı modu dili kaldırıldı; Discord, Roblox, Wattpad, Bigo Live, Azar, Tango, LiVU, IMVU ve Blogspot hedefleri seçilebilir kapsam olarak yönetiliyor." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Web hedeflerinde genel tarayıcı exe'leri tünele alınmıyor. Sadece Astral.WebProxy tünele dahil ediliyor ve yalnız seçili domainler proxy/PAC kuralına giriyor." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Eski Discorder kurulumundan gelen kullanıcılar Astral güncelleme asset'leriyle aynı klasör üzerinde güvenli geçiş alabiliyor." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Ana ekrandaki hedef kapsamı paneli 5+4 isimli ürün kartlarına döndürüldü; footer release notu ve GitHub ikonları yüksek DPI'da kırpılmayacak şekilde iç boşluk aldı." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,12"
                                Padding="16"
                                CornerRadius="8"
                                BorderBrush="#55F9D66B"
                                BorderThickness="1"
                                Background="#4C1C1A12">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningBrush}"
                                           Text="BAĞLANTI NOTU" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="13"
                                           LineHeight="21"
                                           TextWrapping="Wrap"
                                           Text="Astral bağlı demeden önce WireSock sanal adaptörünün aktifleşmesini ve tünel handshake kanıtını bekler. Adaptör Down kalırsa bağlantıyı başarılı saymaz, PAC/proxy kapsamını temizler ve tanılama paketinde kök nedeni görünür bırakır." />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="13"
                                           LineHeight="21"
                                           TextWrapping="Wrap"
                                           Text="Windows kod imzası bu pakette sertifika olmadığı için uygulanmadı. Web hedefleri HTTPS içeriğini çözmez; CONNECT host allowlist'iyle çalışır." />
                            </StackPanel>
                        </Border>

                        <TextBlock FontSize="11"
                                   LineHeight="18"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="SHA256: Paket üretildikten sonra GitHub release asset'i ile doğrulanır." />
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Bu not, geçiş sürümünü uygulama içinden hızlıca okuyabilmek için eklendi." />
                    <Button Grid.Column="1"
                            Margin="0,0,10,0"
                            Height="40"
                            Style="{StaticResource CommandButtonStyle}"
                            Click="OpenReleasePage_Click"
                            Content="GitHub release"
                            ToolTip="Sürüm sayfasını aç" />
                    <Button Grid.Column="2"
                            Height="40"
                            Style="{StaticResource PrimaryCommandButtonStyle}"
                            Click="Close_Click"
                            Content="Kapat" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

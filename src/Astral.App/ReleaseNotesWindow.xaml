<Window x:Class="Astral.App.ReleaseNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Astral sürüm notları"
        Width="720"
        Height="640"
        MinWidth="720"
        MinHeight="580"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="22">
        <Border BorderBrush="{StaticResource PremiumLineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EF09131F" Offset="0" />
                    <GradientStop Color="#D914253A" Offset="0.48" />
                    <GradientStop Color="#C0181730" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="38"
                                  Direction="270"
                                  Opacity="0.46"
                                  ShadowDepth="0"
                                  Color="#63D9FF" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="54"
                            Height="54"
                            CornerRadius="14"
                            BorderBrush="#B77DEBFF"
                            BorderThickness="1">
                        <Border.Background>
                            <RadialGradientBrush Center="0.42,0.34"
                                                 GradientOrigin="0.3,0.22"
                                                 RadiusX="0.85"
                                                 RadiusY="0.85">
                                <GradientStop Color="#767DEBFF" Offset="0" />
                                <GradientStop Color="#345DFF92" Offset="0.48" />
                                <GradientStop Color="#A0101D31" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                        <Viewbox Width="26"
                                 Height="26"
                                 Stretch="Uniform">
                            <Canvas Width="24"
                                    Height="24"
                                    ClipToBounds="False">
                                <Path Stroke="{StaticResource PrimaryTextBrush}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Data="M6,3.5 L15.5,3.5 L20,8 L20,20.5 L6,20.5 Z M15.5,3.5 L15.5,8 L20,8 M9,11 L17,11 M9,14.5 L17,14.5 M9,18 L14,18" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="Astral v2.2.11" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="WireSock transparent mode readiness, kapsam doğrulaması ve bağlantı hotfix'i" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Margin="0,24,0,20"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Margin="0,0,0,12"
                                Padding="16"
                                CornerRadius="8"
                                BorderBrush="#5F8EA7FF"
                                BorderThickness="1"
                                Background="#63101D31">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentCyanBrush}"
                                           Text="KISA ÖZET" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="14"
                                           LineHeight="21"
                                           TextWrapping="Wrap"
                                           Text="Bu sürüm Astral'ın seçili uygulama ve web hedefleri için dar kapsamlı bağlantı yöneticisi davranışını güçlendirir. Hedef kartları gerçek ürün ikonları ve açık state bilgisiyle görünür; uygulama hedef programları açmaz veya yenilemez, yalnızca seçili girişlerin tünel kapsamını hazırlar." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,12"
                                Padding="16"
                                CornerRadius="8"
                                BorderBrush="#5263D9FF"
                                BorderThickness="1"
                                Background="#4E101D31">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="ANA DEĞİŞİKLİKLER" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Discord, Roblox, Wattpad, Bigo Live, Azar, Tango, LiVU, IMVU ve Blogspot için gerçek renkli hedef ikonları eklendi." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Hedef kartları Hazır, Seçili, Bağlanıyor, Kapsamda, Sorunlu ve Pasif durumlarını tooltip ve durum satırıyla gösterir." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Web hedeflerinde genel tarayıcı exe'leri tünele alınmıyor. Sadece Astral.WebProxy tünele dahil ediliyor ve yalnız seçili domainler proxy/PAC kuralına giriyor." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Kapanış, yeniden başlatma, onarım ve profil temizleme akışlarında timeout ve UI donma riski azaltıldı." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; WireSock varsayılan transparent mode artık sanal adaptör zorunluluğu gibi yorumlanmıyor; süreç sağlıklı kaldığında hedef kapsamı hazır sayılıyor." />
                                <TextBlock FontSize="13"
                                           LineHeight="22"
                                           TextWrapping="Wrap"
                                           Text="&#x2022; Güncelleme asset'leri yalnız Astral adıyla doğrulanıyor ve yeni sürüm yoksa güncelleme butonu görünmez kalıyor." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,12"
                                Padding="16"
                                CornerRadius="8"
                                BorderBrush="#55F9D66B"
                                BorderThickness="1"
                                Background="#4C1C1A12">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningBrush}"
                                           Text="BAĞLANTI NOTU" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="13"
                                           LineHeight="21"
                                           TextWrapping="Wrap"
                                           Text="Astral varsayılan WireSock transparent mode'da sanal adaptör zorunluymuş gibi davranmaz. WireSock süreci erken kapanırsa bağlantıyı hata sayar; süreç sağlıklı kalırsa seçili hedef kapsamı ve proxy/PAC planını hazır kabul eder." />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="13"
                                           LineHeight="21"
                                           TextWrapping="Wrap"
                                           Text="Windows kod imzası bu pakette sertifika olmadığı için uygulanmadı. Web hedefleri HTTPS içeriğini çözmez; CONNECT host allowlist'iyle çalışır." />
                            </StackPanel>
                        </Border>

                        <TextBlock FontSize="11"
                                   LineHeight="18"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="SHA256: Paket üretildikten sonra GitHub release asset'i ile doğrulanır." />
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Bu not, v2.2.11 hotfix kapsamını uygulama içinden hızlıca okuyabilmek için eklendi." />
                    <Button Grid.Column="1"
                            Margin="0,0,10,0"
                            Height="40"
                            Style="{StaticResource CommandButtonStyle}"
                            Click="OpenReleasePage_Click"
                            Content="GitHub release"
                            ToolTip="Sürüm sayfasını aç" />
                    <Button Grid.Column="2"
                            Height="40"
                            Style="{StaticResource PrimaryCommandButtonStyle}"
                            Click="Close_Click"
                            Content="Kapat" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

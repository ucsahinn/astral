<Window x:Class="Astral.App.TargetSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hedef Merkezi"
        Width="940"
        Height="700"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#07101D"
        Foreground="{StaticResource PrimaryTextBrush}">
    <Window.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="#5C101D31" />
            <Setter Property="BorderBrush" Value="#9B8EC8FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#7B152945" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#D07DEBFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#90445DFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="#5C101D31" />
            <Setter Property="BorderBrush" Value="#789CD4FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="SelectionBrush" Value="#6A5DFF92" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}" />
                                <TextBlock x:Name="Watermark"
                                           Margin="{TemplateBinding Padding}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           IsHitTestVisible="False"
                                           Text="{TemplateBinding Tag}"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#D07DEBFF" />
                            </Trigger>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="#52101D31" />
            <Setter Property="BorderBrush" Value="#5F8EC8FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Border x:Name="FocusRing"
                                BorderBrush="Transparent"
                                BorderThickness="2"
                                CornerRadius="10"
                                Padding="1">
                            <Border x:Name="Card"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Border x:Name="SelectedBadge"
                                            Width="24"
                                            Height="24"
                                            CornerRadius="12"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Background="#E65DFF92"
                                            BorderBrush="#F5F7FB"
                                            BorderThickness="1"
                                            Visibility="Collapsed"
                                            Panel.ZIndex="2">
                                        <Path x:Name="Tick"
                                              Data="M6,12 L10,16 L18,8"
                                              Stroke="#07101D"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Border>
                                    <ContentPresenter Margin="0"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#6A13243C" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="#D07DEBFF" />
                                <Setter TargetName="SelectedBadge" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="#BC5DFF92" />
                                <Setter TargetName="Card" Property="Background" Value="#6815253D" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="#F57DEBFF" />
                                <Setter TargetName="FocusRing" Property="BorderBrush" Value="#D07DEBFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="22">
        <Border CornerRadius="8"
                BorderBrush="#9B8EC8FF"
                BorderThickness="1"
                Padding="22">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E70B1422" Offset="0" />
                    <GradientStop Color="#CF17243B" Offset="0.52" />
                    <GradientStop Color="#B4101D31" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="42"
                                  Direction="270"
                                  Opacity="0.45"
                                  ShadowDepth="0"
                                  Color="#63D9FF" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock FontSize="26"
                                   FontWeight="SemiBold"
                                   Text="Hedef Merkezi" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Seçilen hedefler tünele alınır; diğer trafik DIRECT kalır." />
                    </StackPanel>
                    <Button DockPanel.Dock="Right"
                            Width="38"
                            Height="34"
                            IsCancel="True"
                            ToolTip="Kapat"
                            AutomationProperties.Name="Kapat">
                        <TextBlock Text="×" FontSize="18" />
                    </Button>
                </DockPanel>

                <TextBox Grid.Row="1"
                         x:Name="SearchBox"
                         Margin="0,18,0,0"
                         Height="40"
                         Padding="12,8"
                         Tag="Filtrelemek için yazınız..."
                         TextChanged="SearchBox_TextChanged"
                         ToolTip="Hedefleri filtrele"
                         AutomationProperties.Name="Filtrelemek için yazınız..." />

                <ScrollViewer Grid.Row="2"
                              Margin="0,16,0,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <WrapPanel x:Name="TargetCardsPanel" />
                        <Border Margin="0,16,0,0"
                                Padding="14"
                                CornerRadius="8"
                                BorderBrush="#3CFFFFFF"
                                BorderThickness="1"
                                Background="#26101D31">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Özel EXE" />
                                    <TextBox x:Name="CustomExecutableTextBox"
                                             Margin="0,6,0,0"
                                             Height="34"
                                             ToolTip="Mutlak .exe yolu"
                                             AutomationProperties.Name="Özel EXE yolu" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Margin="10,0,0,0">
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Özel Domain" />
                                    <TextBox x:Name="CustomDomainTextBox"
                                             Margin="0,6,0,0"
                                             Height="34"
                                             ToolTip="example.com veya *.example.com"
                                             AutomationProperties.Name="Özel domain" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="3"
                      Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="SelectedSummary"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="ValidationMessage"
                                   Margin="0,4,0,0"
                                   Foreground="#FFFF8EA1"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <Button MinWidth="92"
                                Margin="0,0,10,0"
                                IsCancel="True"
                                Content="Vazgeç" />
                        <Button MinWidth="92"
                                IsDefault="True"
                                Click="SaveButton_Click"
                                Content="Kaydet" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
